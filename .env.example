# =============================================================================
# safe-codegen 环境变量模板
# 使用步骤：复制为 .env，填上你的 key，取消对应方案注释即可。
# =============================================================================

# -----------------------------------------------------------------------------
# 方案 A：只用一套后端（例如智谱 GLM）
# -----------------------------------------------------------------------------
# SAFE_CODEGEN_BACKEND=openai
# SAFE_CODEGEN_OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# SAFE_CODEGEN_OPENAI_MODEL=glm-4-flash
# OPENAI_API_KEY=你的智谱API_KEY

# -----------------------------------------------------------------------------
# 方案 B：DeepSeek（把下面几行取消注释，并填上你的 DeepSeek API Key）
# -----------------------------------------------------------------------------
# SAFE_CODEGEN_BACKEND=openai
# SAFE_CODEGEN_OPENAI_BASE_URL=https://api.deepseek.com
# SAFE_CODEGEN_OPENAI_MODEL=deepseek-chat
# OPENAI_API_KEY=你的DeepSeek_API_KEY

# -----------------------------------------------------------------------------
# 方案 B：主后端=智谱，验证后端=DeepSeek（两套 key 都用上）
# -----------------------------------------------------------------------------
# 主后端：智谱（大量调用）
SAFE_CODEGEN_BACKEND=openai
SAFE_CODEGEN_OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
SAFE_CODEGEN_OPENAI_MODEL=glm-4-flash
SAFE_CODEGEN_OPENAI_API_KEY=请替换为你的智谱API_KEY

# 验证后端：基座 Layer1 安全审计（双模型之一）+ 最后验收 Layer3 主审（完整性/可用性/安全合规）
SAFE_CODEGEN_VALIDATION_BACKEND=openai
SAFE_CODEGEN_VALIDATION_BASE_URL=https://api.deepseek.com
SAFE_CODEGEN_OPENAI_VALIDATION_MODEL=deepseek-chat
SAFE_CODEGEN_VALIDATION_API_KEY=请替换为你的DeepSeekAPI_KEY

# -----------------------------------------------------------------------------
# 可选：离线/测试时用 mock，不消耗任何 API
# -----------------------------------------------------------------------------
# SAFE_CODEGEN_BACKEND=mock

# -----------------------------------------------------------------------------
# 可选：仅 Layer 3 用另一模型（同 key 不同模型名）
# -----------------------------------------------------------------------------
# SAFE_CODEGEN_VALIDATION_BACKEND=openai
# SAFE_CODEGEN_OPENAI_VALIDATION_MODEL=gpt-4o
